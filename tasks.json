{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Hospital Managment System (wxWidgets)",
      "type": "shell",
      "command": "C:/msys64/mingw64/bin/clang++.exe",
      "args": [
        "${workspaceFolder}/App.cpp",
        "${workspaceFolder}/MainFrame.cpp",
        "${workspaceFolder}/Database.cpp",
        "-o",
        "${workspaceFolder}/HospitalSystem.exe",
        "-I",
        "C:/msys64/mingw64/lib/wx/include/msw-unicode-3.2",
        "-I",
        "C:/msys64/mingw64/include/wx-3.2",
        "-I",
        "C:/mysql-connector-c++/include",
        "-I",
        "C:/mysql-connector-c++/include/jdbc",
        "-L",
        "C:/msys64/mingw64/lib",
        "-lwx_mswu_aui-3.2",
        "-lwx_mswu_propgrid-3.2",
        "-lwx_mswu_xrc-3.2",
        "-lwx_mswu_html-3.2",
        "-lwx_mswu_qa-3.2",
        "-lwx_mswu_core-3.2",
        "-lwx_baseu_xml-3.2",
        "-lwx_baseu_net-3.2",
        "-lwx_baseu-3.2",
        "-L",
        "C:/mysql-connector-c++/lib64/vs14",
        "-lmysqlcppconn",
        "-std=c++17",
        "-Wall",
        "-mwindows",
        "-DUNICODE",
        "-D_UNICODE",
        "-DWXUSINGDLL",
        "-D__WXMSW__",
        "-fuse-ld=lld"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}

